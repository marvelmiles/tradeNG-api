NODE_ENV=development
PORT=3000
APP_NAME=TradeNG
FRONTEND_URL=http://localhost:3000
SERVER_URL=http://localhost:5000
API_VERSION=v1

MONGODB_URI=mongodb://localhost:27017/tradeng

JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRY=7d

EMAILJS_SERVICE_ID=your-emailjs-service-id
EMAILJS_TEMPLATE_ID=your-emailjs-template-id
EMAILJS_PUBLIC_KEY=your-emailjs-public-key
EMAILJS_PRIVATE_KEY=your-emailjs-private-key
SMTP_FROM="TradeNG <noreply@tradeng.com>"

PLATFORM_FEE_PERCENT=5
OTP_EXPIRY_MINUTES=15
ACCOUNT_EXPIRY_DAYS=7
AUTO_RELEASE_HOURS=48

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

NOMBA_CLIENT_ID=your-nomba-client-id
NOMBA_CLIENT_SECRET=your-nomba-client-secret
NOMBA_ACCOUNT_ID=your-nomba-account-id
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_WEBHOOK_SECRET=your-nomba-webhook-secret

SUPPORT_INBOX_EMAIL=support@tradeng.com
SOCKET_CORS_ORIGIN=*
WITHDRAWAL_MIN_AMOUNT=1000
